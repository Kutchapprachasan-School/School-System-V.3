// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 0. ENUMS (จำกัดความเพี้ยนของข้อมูลประเภทสถานะ)
// ==========================================

enum StudentStatus {
  STUDYING
  GRADUATED
  MOVED
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SarabanStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  ROLLBACK_PENDING
  ROLLBACKED
}

enum RowImportStatus {
  SUCCESS
  FAILED
}

enum ImportChunkStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ABANDONED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  LOGIN
  LOGOUT
}

enum ImportDomain {
  STUDENT
  HOME_VISIT
  ACADEMIC
  SARABAN
}


// ==========================================
// 1. DOMAIN: AUTHENTICATION, USERS & RBAC
// ==========================================

model User {
  id            String      @id @default(dbgenerated("gen_random_uuid()"))
  username      String      @unique
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false)
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?   
  createdBy     String?
  updatedBy     String?

  sessions      Session[]
  accounts      Account[]
  userRoles     UserRole[]
  auditLogs     AuditLog[]
  fileRecords   FileRecord[]
  importJobs    ImportJob[]
  academicDocs  AcademicDoc[] 

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()"))
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()"))
  name        String           @unique // e.g. "ADMIN", "TEACHER", "STUDENT"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  
  userRoles   UserRole[]
  permissions RolePermission[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()"))
  action      String           @unique // e.g. "student:create"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}


// ==========================================
// 2. DOMAIN: AUDIT & SYSTEM MONITORING
// ==========================================

model AuditLog {
  id            String      @id @default(dbgenerated("gen_random_uuid()"))
  userId        String?  
  action        AuditAction   
  entityName    String   
  entityId      String
  changedFields Json?       
  before        Json?    
  after         Json?    
  ipAddress     String?
  userAgent     String?
  correlationId String?
  createdAt     DateTime    @default(now())

  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityName, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}


// ==========================================
// 3. DOMAIN: FILE MANAGEMENT (METADATA)
// ==========================================

model FileRecord {
  id          String       @id @default(dbgenerated("gen_random_uuid()"))
  fileName    String
  bucketName  String       
  storagePath String       
  mimeType    String
  sizeBytes   BigInt       
  uploaderId  String?
  checksum    String
  width       Int?
  height      Int?
  capturedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  uploader    User?        @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  
  academicDocs AcademicDoc[]
  sarabanDocs  Saraban[]
  visitsOutside HomeVisit[]  @relation("ImgHouseOutside")
  visitsInside  HomeVisit[]  @relation("ImgHouseInside")

  @@index([deletedAt])
  @@map("file_records")
}


// ==========================================
// 4. DOMAIN: DATA IMPORT MANAGEMENT
// ==========================================

model ImportJob {
  id            String          @id @default(dbgenerated("gen_random_uuid()"))
  targetDomain  ImportDomain          
  fileName      String
  status        ImportJobStatus @default(PENDING) 
  totalRows     Int             @default(0)
  successRows   Int             @default(0)
  failedRows    Int             @default(0)
  durationMs    Int?            
  errorMessage  String?
  createdBy     String?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  chunks        ImportChunk[]   
  rowLogs       ImportRowLog[]

  @@map("import_jobs")
}

model ImportChunk {
  id          String    @id 
  importJobId String
  status      ImportChunkStatus    
  payloadHash String    
  durationMs  Int?
  successRows Int       @default(0)
  failedRows  Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime? 
  heartbeatAt DateTime  @default(now())
  retryCount  Int       @default(0)
  lastError   String?
  
  job         ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@map("import_chunks")
}

model ImportRowLog {
  id                String          @id @default(dbgenerated("gen_random_uuid()"))
  importJobId      String
  chunkId           String          
  rowIndex          Int             
  status            RowImportStatus
  originalData      Json            
  errorDetails      String?         
  targetEntityId    String?         
  entitySnapshot    Json?           
  entityUpdatedAt   DateTime?       
  ipAddress         String?
  userAgent         String?
  correlationId     String?
  createdAt         DateTime        @default(now())

  job               ImportJob       @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([importJobId, chunkId])
  @@index([status])
  @@index([targetEntityId])
  @@map("import_row_logs")
}


// ==========================================
// 5. DOMAIN: STUDENT MANAGEMENT
// ==========================================

model Student {
  id           String        @id @default(dbgenerated("gen_random_uuid()"))
  studentId    String        
  studentName  String
  classLevel   String
  room         String
  status       StudentStatus @default(STUDYING) 
  profileImage String?     
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  createdBy    String?
  updatedBy    String?

  homeVisits   HomeVisit[]   

  @@index([deletedAt])
  @@map("students")
}

model HomeVisit {
  id                String    @id @default(dbgenerated("gen_random_uuid()"))
  studentId         String    
  visitStatus       String    
  visitDate         DateTime? @db.Date
  informantRelation String?
  photoSource       String?
  mapLat            Float?
  mapLong           Float?
  gpsAccuracy       Float?
  gpsCapturedAt     DateTime?
  gpsSource         String?
  gpsOverrideReason String?
  
  imgHouseOutsideId String?
  imgHouseInsideId  String?

  houseNo           String?
  houseMoo          String?
  houseRoad         String?
  houseTambon       String?
  houseAmphoe       String?
  houseProvince     String?
  
  familyIncome      Decimal?  @db.Decimal(12, 2)
  familyExpense     Decimal?  @db.Decimal(12, 2)
  familyDebt        Decimal?  @db.Decimal(12, 2)
  
  teacherSummary    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  createdBy         String?
  updatedBy         String?

  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  imgHouseOutside   FileRecord? @relation("ImgHouseOutside", fields: [imgHouseOutsideId], references: [id], onDelete: SetNull)
  imgHouseInside    FileRecord? @relation("ImgHouseInside", fields: [imgHouseInsideId], references: [id], onDelete: SetNull)

  @@index([studentId, deletedAt])
  @@index([imgHouseOutsideId])
  @@index([imgHouseInsideId])
  @@index([deletedAt])
  @@map("home_visits")
}


// ==========================================
// 6. DOMAIN: ACADEMIC MANAGEMENT
// ==========================================

model AcademicDoc {
  id           String      @id @default(dbgenerated("gen_random_uuid()"))
  workSystem   String      
  details      String?
  year         String
  term         String
  teacherId    String      
  status       DocStatus   @default(PENDING) 
  comment      String?
  fileRecordId String?     

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  createdBy    String?
  updatedBy    String?

  teacher      User        @relation(fields: [teacherId], references: [id])
  fileRecord   FileRecord? @relation(fields: [fileRecordId], references: [id], onDelete: SetNull)

  @@index([teacherId, deletedAt])
  @@index([fileRecordId])
  @@index([deletedAt])
  @@map("academic_docs")
}


// ==========================================
// 7. DOMAIN: DOCUMENT MANAGEMENT (SARABAN)
// ==========================================

model Saraban {
  id           String        @id @default(dbgenerated("gen_random_uuid()"))
  docNumber    String        
  docType      String        
  year         String        
  date         DateTime
  title        String
  fromDept     String      
  toDept       String      
  status       SarabanStatus @default(DRAFT) 
  fileRecordId String?     

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  createdBy    String?
  updatedBy    String?

  fileRecord   FileRecord?   @relation(fields: [fileRecordId], references: [id], onDelete: SetNull)

  @@unique([year, docNumber, docType])
  @@index([deletedAt])
  @@map("saraban_docs")
}
